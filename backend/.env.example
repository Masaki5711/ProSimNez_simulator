# Application Settings
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=your-secure-jwt-secret-key
DEBUG=false

# Database Settings
DATABASE_URL=sqlite:///./prosimulator.db

# Simulation Settings
SIMULATION_DURATION=3600
SIMULATION_TIME_SCALE=1.0
SIMULATION_MAX_DURATION_HOURS=24.0
SIMULATION_BROADCAST_INTERVAL=1

# Process Settings
PROCESS_DEFAULT_TIME=60.0
PROCESS_BREAKDOWN_PROB=0.001
PROCESS_MAINTENANCE_TIME=3600
PROCESS_BOTTLENECK_BUFFER=10

# Transport Settings
TRANSPORT_DEFAULT_SPEED=1.0
TRANSPORT_LOAD_CAPACITY=100.0
TRANSPORT_BATTERY_LEVEL=100.0
TRANSPORT_DELIVERY_TIME=300
TRANSPORT_TRAFFIC_FACTOR=1.0

# Kanban Settings
KANBAN_DEFAULT_COUNT=3

# Quality Settings
QUALITY_REWORK_COST=300

# Monitoring Settings
MONITORING_DURATION=3600
MONITORING_ANALYSIS_WINDOW=1800

# WebSocket Settings
WEBSOCKET_TIMEOUT=300
